<Window x:Class="Lavender.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Lavender"
        Height="720"
        Width="1100"
        Loaded="Window_Loaded"
        Background="#111827">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="3*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0"
                Background="#0F172A"
                Padding="16">

            <DockPanel LastChildFill="True">

                <!-- App Title -->
                <StackPanel DockPanel.Dock="Top">
                    <TextBlock Text="Lavender"
                               Foreground="#C4B5FD"
                               FontSize="26"
                               FontWeight="Bold"
                               Margin="0,0,0,20"/>

                    <Button Content="+ New Chat"
                            Height="42"
                            Background="#7C3AED"
                            Foreground="White"
                            BorderThickness="0"
                            FontWeight="SemiBold"
                            Margin="0,0,0,20"/>
                </StackPanel>

                <!-- Bottom Settings -->
                <StackPanel DockPanel.Dock="Bottom">
                    <Button Content="Settings"
                            Height="38"
                            Background="#1E293B"
                            Foreground="White"
                            BorderThickness="0"/>
                </StackPanel>

                <!-- Recent Chats -->
                <StackPanel>
                    <TextBlock Text="Recent"
                               Foreground="#94A3B8"
                               FontSize="13"
                               Margin="0,0,0,8"/>

                    <Button Content="Unity Assistant"
                            HorizontalContentAlignment="Left"
                            Background="Transparent"
                            Foreground="White"
                            BorderThickness="0"
                            Padding="8"
                            Margin="0,2"/>

                </StackPanel>

            </DockPanel>
        </Border>

        <!-- Main View -->
        <Grid Grid.Column="1"
              Background="#111827"
              Margin="0">

            <Grid.RowDefinitions>
                <RowDefinition Height="64"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="110"/>
            </Grid.RowDefinitions>

            <!-- Top Bar -->
            <Border Grid.Row="0"
                    Background="#111827"
                    BorderBrush="#1F2937"
                    BorderThickness="0,0,0,1"
                    Padding="24,0">

                <TextBlock Text="New Chat"
                           Foreground="White"
                           FontSize="18"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
            </Border>

            <!-- Chat Messages -->
            <ScrollViewer x:Name="ChatScrollViewer"
                          Grid.Row="1"
                          Padding="32"
                          VerticalScrollBarVisibility="Auto">

                <StackPanel x:Name="ChatMessagesPanel"/>
            </ScrollViewer>

            <!-- Chat Input -->
            <Border Grid.Row="2"
                    Background="#111827"
                    BorderBrush="#1F2937"
                    BorderThickness="0,1,0,0"
                    Padding="32,20">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="90"/>
                    </Grid.ColumnDefinitions>

                    <TextBox x:Name="UserInputBox"
                             Grid.Column="0"
                             Height="52"
                             Background="#1F2937"
                             Foreground="White"
                             BorderBrush="#374151"
                             BorderThickness="1"
                             Padding="16"
                             FontSize="15"
                             Text="Ask Lavender anything..."
                             VerticalContentAlignment="Center"/>

                    <Button x:Name="SendButton"
                            Grid.Column="1"
                            Content="Send"
                            Height="52"
                            Margin="12,0,0,0"
                            Background="#7C3AED"
                            Foreground="White"
                            BorderThickness="0"
                            FontWeight="SemiBold"
                            Click="SendButton_Click"/>
                </Grid>
            </Border>

        </Grid>
    </Grid>
</Window>