<Window x:Class="Lavender.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Lavender"
        Title="Lavender"
        Height="720"
        Width="1200"
        Loaded="Window_Loaded"
        Background="#111827">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="380"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar / Project Explorer -->
        <Border Grid.Column="0"
                Background="#0F172A"
                Padding="16">

            <DockPanel LastChildFill="True">

                <StackPanel DockPanel.Dock="Top">
                    <TextBlock Text="Lavender"
                               Foreground="#C4B5FD"
                               FontSize="26"
                               FontWeight="Bold"
                               Margin="0,0,0,20"/>

                    <Button x:Name="OpenProjectButton"
                            Content="Open Project"
                            Height="42"
                            Background="#7C3AED"
                            Foreground="White"
                            BorderThickness="0"
                            FontWeight="SemiBold"
                            Margin="0,0,0,20"
                            Click="OpenProject_Click"/>
                </StackPanel>

                <StackPanel DockPanel.Dock="Bottom">
                    <Button Content="Settings"
                            Height="38"
                            Background="#1E293B"
                            Foreground="White"
                            BorderThickness="0"/>
                </StackPanel>

                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Auto">
                    <TreeView x:Name="FolderView"
                              SelectedItemChanged="FolderView_SelectedItemChanged"
                              PreviewMouseMove="FolderView_PreviewMouseMove">

                        <TreeView.Resources>
                            <Style TargetType="{x:Type TreeViewItem}">
                                <Setter Property="HeaderTemplate">
                                    <Setter.Value>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <Image Width="20"
                                                       Height="20"
                                                       Margin="3"
                                                       Source="{Binding 
                                                           RelativeSource={RelativeSource 
                                                               Mode=FindAncestor, 
                                                               AncestorType={x:Type TreeViewItem}},
                                                           Path=Tag,
                                                           Converter={x:Static local:HeaderToImageConverter.Instance}}"/>

                                                <TextBlock VerticalAlignment="Center"
                                                           Foreground="#E5E7EB"
                                                           Text="{Binding}"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </TreeView.Resources>

                    </TreeView>
                </ScrollViewer>

            </DockPanel>
        </Border>

        <!-- Middle: File Preview -->
        <Grid Grid.Column="1"
              Background="#0B1120">

            <Grid.RowDefinitions>
                <RowDefinition Height="64"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="#111827"
                    BorderBrush="#1F2937"
                    BorderThickness="0,0,0,1"
                    Padding="24,0">

                <TextBlock x:Name="PreviewFileNameText"
                           Text="No file selected"
                           Foreground="White"
                           FontSize="18"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
            </Border>

            <Border Grid.Row="1"
                    Margin="24"
                    Background="#111827"
                    BorderBrush="#1F2937"
                    BorderThickness="1"
                    CornerRadius="8">

                

            <RichTextBox x:Name="FilePreviewBox"
                    Background="#111827"
                    Foreground="#D1D5DB"
                    BorderThickness="0"
                    FontFamily="Consolas"
                    FontSize="14"
                    IsReadOnly="False"
                    AcceptsTab="True"
                    TextChanged="FilePreviewBox_TextChanged"/>
            </Border>
        </Grid>

        <!-- Right: Chat Panel -->
        <Grid Grid.Column="2"
          Background="#111827"
          AllowDrop="True"
          DragOver="ChatPanel_DragOver"
          Drop="ChatPanel_Drop">

            <Grid.RowDefinitions>
                <RowDefinition Height="64"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="140"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="#111827"
                    BorderBrush="#1F2937"
                    BorderThickness="1,0,0,1"
                    Padding="20,0">

                <TextBlock Text="Chat"
                           Foreground="White"
                           FontSize="18"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
            </Border>

            <ScrollViewer x:Name="ChatScrollViewer"
                          Grid.Row="1"
                          Padding="20"
                          VerticalScrollBarVisibility="Auto">

                <StackPanel x:Name="ChatMessagesPanel"/>
            </ScrollViewer>

            <Border Grid.Row="2"
                    Background="#111827"
                    BorderBrush="#1F2937"
                    BorderThickness="1,1,0,0"
                    Padding="20">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock x:Name="SelectedContextText"
                               Grid.Row="0"
                               Text="Context: No file selected"
                               Foreground="#94A3B8"
                               FontSize="13"
                               Margin="0,0,0,8"/>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="80"/>
                        </Grid.ColumnDefinitions>

                        <TextBox x:Name="UserInputBox"
                                 Grid.Column="0"
                                 Height="52"
                                 Background="#1F2937"
                                 Foreground="White"
                                 BorderBrush="#374151"
                                 BorderThickness="1"
                                 Padding="14"
                                 FontSize="14"
                                 Text=""
                                 VerticalContentAlignment="Center"/>

                        <Button x:Name="SendButton"
                                Grid.Column="1"
                                Content="Send"
                                Height="52"
                                Margin="10,0,0,0"
                                Background="#7C3AED"
                                Foreground="White"
                                BorderThickness="0"
                                FontWeight="SemiBold"
                                Click="SendButton_Click"/>
                    </Grid>
                </Grid>
            </Border>

        </Grid>
    </Grid>
</Window>